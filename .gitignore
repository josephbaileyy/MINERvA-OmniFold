# ---------- Tutorial clones (entire subtree) ----------
# Everything under MINERvA101/ is upstream code from the MINERvA 101 tutorial
# (https://minerva-software.fnal.gov/minerva101/) and is NOT mine. The whole
# directory is excluded; only the specific files I edited are re-added below
# via negation patterns.
MINERvA101/**

# Re-add the dir entries so the negations below can match
!MINERvA101/
!MINERvA101/MINERvA-101-Cross-Section/
!MINERvA101/MINERvA-101-Cross-Section/event/
!MINERvA101/MINERvA-101-Cross-Section/util/
!MINERvA101/MINERvA-101-Cross-Section/cuts/

# Files I modified in MINERvA-101-Cross-Section
!MINERvA101/MINERvA-101-Cross-Section/runEventLoop.cpp
!MINERvA101/MINERvA-101-Cross-Section/runEventLoopOmniFold.cpp
!MINERvA101/MINERvA-101-Cross-Section/runEventLoopMod.cpp
!MINERvA101/MINERvA-101-Cross-Section/runEventLoopOmniFold_OLD.cpp
!MINERvA101/MINERvA-101-Cross-Section/runEventLoopOmniFold_OLDEST.cpp
!MINERvA101/MINERvA-101-Cross-Section/CMakeLists.txt
!MINERvA101/MINERvA-101-Cross-Section/ExtractCrossSection.cpp
!MINERvA101/MINERvA-101-Cross-Section/event/CVUniverse.h
!MINERvA101/MINERvA-101-Cross-Section/util/Binning.h
!MINERvA101/MINERvA-101-Cross-Section/cuts/MaxPtMu.h

# ---------- unbinned_unfolding (RooUnfold fork) ----------
