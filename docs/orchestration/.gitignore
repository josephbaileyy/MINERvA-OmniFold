# Runtime lock files are recreated by agentctl and contain no durable state.
state/locks/
state/*.lock
state/usage/

# Successful turn metadata is kept as JSON; empty/provider stderr logs stay local.
runs/**/*.stderr.log

# wakerctl runtime spool: events, claims, ledger, logs are runtime evidence,
# reproducible receipts live in the campaign ledger commits.
state/waker/
